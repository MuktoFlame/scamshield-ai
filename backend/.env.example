# Copy to .env and fill in. Every variable is optional for local development:
# without GEMINI_API_KEY the built-in explainer is used (screenshot upload is
# disabled); without MONGO_URI an in-memory database is used.

# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Primary model + comma-separated fallbacks (tried in order when a model's
# free-tier quota is exhausted). Pick primaries with a high requests-per-day
# limit on your account.
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# MongoDB Atlas connection string (free M0 tier): https://www.mongodb.com/atlas
MONGO_URI=

# Long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# Comma-separated allowed origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
